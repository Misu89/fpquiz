<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/quizFragment">

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.example.fpquiz.ui.quiz.QuizFragment"
        android:label="QuizFragment">

        <action
            android:id="@+id/action_quizFragment_to_resultsFragment"
            app:destination="@id/resultsFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultsFragment"
        android:name="com.example.fpquiz.ui.results.ResultsFragment"
        android:label="ResultsFragment">

        <argument
            android:name="puntuacio"
            app:argType="integer" />

        <argument
            android:name="total"
            app:argType="integer" />
    </fragment>
</navigation>