<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.fpquiz.ui.home.HomeFragment"
        android:label="HomeFragment" />

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.example.fpquiz.ui.quiz.QuizFragment"
        android:label="QuizFragment">

        <argument
            android:name="categoria"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <action
            android:id="@+id/action_quizFragment_to_resultsFragment"
            app:destination="@id/resultsFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultsFragment"
        android:name="com.example.fpquiz.ui.results.ResultsFragment"
        android:label="ResultsFragment">

        <argument android:name="puntuacio" app:argType="integer" />
        <argument android:name="total" app:argType="integer" />

        <action
            android:id="@+id/action_resultsFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.fpquiz.ui.history.HistoryFragment"
        android:label="HistoryFragment" />
</navigation>